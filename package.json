{
  "name": "jan-sync",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "deploy:preview": "pnpm build && wrangler pages deploy dist --project-name jan-sync",
    "test": "vitest run",
    "test:watch": "vitest",
    "release:patch": "pnpm version patch && git push && git push --tags",
    "release:minor": "pnpm version minor && git push && git push --tags",
    "release:major": "pnpm version major && git push && git push --tags"
  },
  "dependencies": {
    "bwip-js": "^4.9.0",
    "idb": "^8.0.3",
    "solid-js": "^1.9.12",
    "workbox-window": "^7.4.0",
    "zxing-wasm": "^3.0.2"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.2.2",
    "@types/node": "^24.12.2",
    "@vite-pwa/assets-generator": "^1.0.2",
    "@vitest/coverage-v8": "^4.1.3",
    "jsdom": "^29.0.2",
    "tailwindcss": "^4.2.2",
    "typescript": "~6.0.2",
    "vite": "^8.0.4",
    "vite-plugin-mkcert": "^1.17.10",
    "vite-plugin-pwa": "^1.2.0",
    "vite-plugin-solid": "^2.11.12",
    "vitest": "^4.1.3",
    "wrangler": "^4.81.0"
  }
}
